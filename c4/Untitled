@startuml
!include <C4/C4_Container>

LAYOUT_LEFT_RIGHT()

Person(user, "Пользователь", "Пользователь системы распределения обращений")

' Границы системы
System_Boundary(system, "Система") {
    Container(frontend, "Клиентская-часть", "React", "Пользовательский интерфейс приложения")
    Container(backend, "Серверная часть", "Golang", "Бизнес-логика приложения")
' Связи
Rel(user, frontend, "Взаимодействует с системой распределения обращений")
Rel(frontend, backend, "Отправляет запросы", "HTTP")

SHOW_LEGEND()
@enduml