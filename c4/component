@startuml
!include <C4/C4_Component>

LAYOUT_LEFT_RIGHT()

title Уровень Компонент (Система распределения обращений)

Component(frontend, "Клиентская-часть", "React", "Пользовательский интерфейс приложения")

' Границы системы
System_Boundary(system, "Система") {
    Component(httpServer, "Модуль обработки HTTP-запросов", "Golang", "Выполняет обработку HTTP-запросов и отправляет ответы")
    Component(crudModule, "Модуль CRUD-операций", "Golang", "Выполняет обработку CRUD-операций")
    Component(workflowModule, "Модуль автоматизаций", "Golang", "Управляет автоматизациями")
    Component(balancerModule, "Модуль распределения обращений", "Golang", "Управляет распределением обращений между сотрудниками")
    ComponentDb(database, "База данных", "PostgreSQL", "Хранит информацию об объектах системы")
    ComponentDb(redis, "Хранилище asynq задач", "Redis", "Хранит информацию о задачах библиотеки asynq")
    ComponentQueue(queue, "Очередь сообщений", "RabbitMQ", "Передает связанные с распределением обращений события")
' Связи
Rel(frontend, httpServer, "Отправляет запросы", "HTTP")
Rel(httpServer, crudModule, "Вызывает CRUD-операции над основными сущностями системы")
Rel(httpServer, workflowModule, "Вызывает операции управления автоматизациями")
Rel(crudModule, database, "Хранение сущностей системы", "SQL")
Rel(workflowModule, database, "Хранение информации об автоматизациях", "SQL")
Rel(crudModule, workflowModule, "Запускает автоматизации")
Rel(workflowModule, crudModule, "Вызывает CRUD-операции для выполнения действий автоматизации")
Rel(crudModule, queue, "Отправляет события для распределения обращений", "TCP")
Rel(queue, balancerModule, "Передает события для распределения обращений", "TCP")
Rel(balancerModule, crudModule, "Вызывает CRUD-операции для назначения сотрудникам обращений")
Rel(balancerModule, redis, "Использует фоновые задачи для распределения обращений")

SHOW_LEGEND()
@enduml